{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stableStringify Test Vectors",
  "description": "Cross-language test vectors for deterministic JSON serialization. Both TypeScript and Python implementations MUST produce identical output for these inputs.",
  "version": "1.0.0",
  "rules": {
    "1": "Object keys MUST be sorted lexicographically (Unicode code point order)",
    "2": "Arrays preserve order (not sorted)",
    "3": "No whitespace (compact JSON)",
    "4": "undefined values MUST be omitted (not serialized)",
    "5": "null values MUST be preserved",
    "6": "Numbers: no trailing zeros, no leading zeros except 0.x",
    "7": "Strings: minimal escaping (only required: \", \\, control chars)",
    "8": "UTF-8 encoding for hash input"
  },
  "vectors": [
    {
      "id": "v001_empty_object",
      "input": {},
      "expectedJson": "{}",
      "expectedSha256": "44136fa355b3678a1146ad16f7e8649e94fb4fc21fe77e8310c060f61caaff8a"
    },
    {
      "id": "v002_simple_object",
      "input": {"b": 2, "a": 1},
      "expectedJson": "{\"a\":1,\"b\":2}",
      "expectedSha256": "abd6e9d2ed3c842e6c4560e5e1c04f55434019b14e03fc7c3f949f5a1e9e8f1e"
    },
    {
      "id": "v003_nested_object",
      "input": {"z": {"b": 2, "a": 1}, "a": 0},
      "expectedJson": "{\"a\":0,\"z\":{\"a\":1,\"b\":2}}",
      "expectedSha256": "7c1b4d4c9d1e5c6a8b9f0e2d3c4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a"
    },
    {
      "id": "v004_array_preserves_order",
      "input": {"arr": [3, 1, 2]},
      "expectedJson": "{\"arr\":[3,1,2]}",
      "expectedSha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
    {
      "id": "v005_null_preserved",
      "input": {"a": null, "b": 1},
      "expectedJson": "{\"a\":null,\"b\":1}",
      "expectedSha256": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2"
    },
    {
      "id": "v006_deeply_nested",
      "input": {
        "level1": {
          "level2": {
            "level3": {
              "z": 3,
              "a": 1,
              "m": 2
            }
          }
        }
      },
      "expectedJson": "{\"level1\":{\"level2\":{\"level3\":{\"a\":1,\"m\":2,\"z\":3}}}}",
      "expectedSha256": "b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2"
    },
    {
      "id": "v007_array_of_objects",
      "input": {
        "items": [
          {"z": 1, "a": 2},
          {"b": 3, "a": 4}
        ]
      },
      "expectedJson": "{\"items\":[{\"a\":2,\"z\":1},{\"a\":4,\"b\":3}]}",
      "expectedSha256": "c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2"
    },
    {
      "id": "v008_unicode_string",
      "input": {"name": "ตู้ครัว", "type": "cabinet"},
      "expectedJson": "{\"name\":\"ตู้ครัว\",\"type\":\"cabinet\"}",
      "expectedSha256": "d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6d7e8f9a0b1c2"
    },
    {
      "id": "v009_numbers",
      "input": {"int": 42, "float": 3.14, "neg": -1, "zero": 0},
      "expectedJson": "{\"float\":3.14,\"int\":42,\"neg\":-1,\"zero\":0}",
      "expectedSha256": "e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2"
    },
    {
      "id": "v010_boolean",
      "input": {"yes": true, "no": false},
      "expectedJson": "{\"no\":false,\"yes\":true}",
      "expectedSha256": "f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2"
    },
    {
      "id": "v011_manifest_like",
      "description": "Simulates manifest structure for signing",
      "input": {
        "version": "1.0",
        "job": {
          "jobId": "job_001",
          "specState": "RELEASED"
        },
        "chain": {
          "manifestHash": {
            "algo": "SHA-256",
            "hex": "abc123"
          }
        }
      },
      "expectedJson": "{\"chain\":{\"manifestHash\":{\"algo\":\"SHA-256\",\"hex\":\"abc123\"}},\"job\":{\"jobId\":\"job_001\",\"specState\":\"RELEASED\"},\"version\":\"1.0\"}",
      "expectedSha256": "a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3"
    },
    {
      "id": "v012_empty_array",
      "input": {"items": []},
      "expectedJson": "{\"items\":[]}",
      "expectedSha256": "b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3"
    },
    {
      "id": "v013_mixed_nested",
      "input": {
        "z": [{"b": 1, "a": 2}],
        "a": {"y": null, "x": true}
      },
      "expectedJson": "{\"a\":{\"x\":true,\"y\":null},\"z\":[{\"a\":2,\"b\":1}]}",
      "expectedSha256": "c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3"
    }
  ],
  "note": "SHA-256 hashes in this file are PLACEHOLDERS. Run the canonical TypeScript implementation first to generate actual hashes, then freeze them as the golden standard."
}
