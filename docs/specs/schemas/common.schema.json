{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monolith.local/schemas/common.schema.json",
  "title": "MONOLITH Factory Packet v2 Common Definitions",
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "canonicalPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[<>:\"|?*\\u0000-\\u001F\\u007F])(?!.*/$).+$",
      "x-monolith-normalization": "Unicode NFC",
      "x-monolith-windowsSegmentRules": "nonempty; not dot/dotdot; no reserved device names; no trailing dot or space"
    },
    "sha256Hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "sha256Id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "uuidV4": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "timestampMsUtc": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}Z$"
    },
    "signedUm": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "nonNegativeUm": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "positiveUm": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "vectorUm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xUm", "yUm", "zUm"],
      "properties": {
        "xUm": { "$ref": "#/$defs/signedUm" },
        "yUm": { "$ref": "#/$defs/signedUm" },
        "zUm": { "$ref": "#/$defs/signedUm" }
      }
    },
    "directionMicro": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xMicro", "yMicro", "zMicro"],
      "properties": {
        "xMicro": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "yMicro": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "zMicro": { "type": "integer", "minimum": -1000000, "maximum": 1000000 }
      }
    }
  }
}
