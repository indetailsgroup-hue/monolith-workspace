{
  "name": "monolith-factory-server",
  "version": "0.13.2",
  "type": "module",
  "description": "Monolith Factory Server - Multi-process bundle verification and export workers",
  "main": "dist/api/index.js",
  "bin": {
    "monolith-receipt-verify": "./dist/cli/receiptVerify.js"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "dev:all": "tsx watch src/index.ts",
    "build": "tsc",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "verify": "tsx src/cli/receiptVerify.ts",
    "test": "vitest"
  },
  "dependencies": {
    "bullmq": "^5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "pdfkit": "^0.17.2",
    "uuid": "^9.0.0",
    "yauzl": "^3.2.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.17.4",
    "@types/uuid": "^9.0.7",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  }
}
