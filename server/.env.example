# IIMOS Factory Server Environment Variables

# Redis connection for BullMQ job queue
REDIS_URL=redis://localhost:6379

# API server port
API_PORT=3001

# Data directory for CAS storage
DATA_DIR=./data

# Worker concurrency (number of parallel export jobs)
WORKER_CONCURRENCY=2

# Base URL for signed download URLs
BASE_URL=http://localhost:3001

# Secret for HMAC-signed download URLs
# IMPORTANT: Change this in production!
SIGNED_URL_SECRET=change_me_to_a_long_random_string

# Time-to-live for signed URLs (seconds)
SIGNED_URL_TTL_SECONDS=600
