# IIMOS Factory Server Environment Variables

# Redis connection for BullMQ job queue
REDIS_URL=redis://localhost:6379

# API server port
API_PORT=3001

# Data directory for CAS storage
DATA_DIR=./data

# Worker concurrency (number of parallel export jobs)
WORKER_CONCURRENCY=2

# Base URL for signed download URLs
BASE_URL=http://localhost:3001

# Secret for HMAC-signed download URLs
# IMPORTANT: Change this in production!
SIGNED_URL_SECRET=change_me_to_a_long_random_string

# Time-to-live for signed URLs (seconds)
SIGNED_URL_TTL_SECONDS=600

# ============================================================================
# Security boundary (FS-B0-02)  --  REQUIRED. The server refuses to start
# (exit 1) unless the two secrets below are set to a strong value (>= 16 chars,
# not a known placeholder). Fail-closed by design.
# ============================================================================

# Shared bearer token required on every route except /health (and the
# signed-URL /download). Clients send: Authorization: Bearer <this value>.
FACTORY_API_TOKEN=change_me_to_a_long_random_token

# CORS origin allowlist (comma-separated). Empty = no cross-origin browser
# access; server-to-server calls (no Origin header) are always allowed.
FACTORY_ALLOWED_ORIGINS=

# Rate limit (per IP, fixed window). Defaults: 60000ms window, 120 requests.
FACTORY_RATE_WINDOW_MS=60000
FACTORY_RATE_MAX=120

# Max JSON request body size (default 2mb).
FACTORY_JSON_LIMIT=2mb
