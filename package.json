{
  "name": "monolith-workspace",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:gate": "vitest run src/gate/ --reporter=verbose",
    "test:gate:watch": "vitest src/gate/",
    "test:gate:coverage": "vitest run src/gate/ --coverage",
    "test:minifix": "vitest run src/gate/rules/connectors/__tests__/ --reporter=verbose",
    "test:governance-tooling": "node --test scripts/governance-tooling.test.mjs scripts/governance-tooling-controls.test.mjs",
    "test:schema-bundle": "node --test scripts/schema-bundle.test.mjs",
    "test:node": "node --test scripts/governance-tooling.test.mjs scripts/governance-tooling-controls.test.mjs scripts/schema-bundle.test.mjs scripts/governance-semantic-status.test.mjs scripts/dogfood-start.test.mjs scripts/dogfood-record.test.mjs scripts/readiness-status.test.mjs",
    "test:s17-4": "npm --prefix server run test:s17-4",
    "gate:bypass-scan": "npx ts-node scripts/gates/bypass-scan.ts",
    "gate:bypass-scan:strict": "npx ts-node scripts/gates/bypass-scan.ts --strict",
    "gate:bypass-scan:json": "npx ts-node scripts/gates/bypass-scan.ts --json",
    "gate:bypass-scan:g9": "npx ts-node scripts/gates/bypass-scan.ts --gate G9 --scope",
    "gate:bypass-scan:g10": "npx ts-node scripts/gates/bypass-scan.ts --gate G10 --scope",
    "build:all": "npm run build --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:all": "npm run format --workspaces --if-present",
    "typecheck:all": "tsc -b tsconfig.build.json",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "verify": "npm run lint && npm run test:run && npm run test:node && npm run typecheck:all && npm run e2e:smoke",
    "verify:full": "npm run lint && npm run test:run && npm run test:node && npm run typecheck:all && npm run e2e"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@react-three/csg": "^4.0.0",
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "@supabase/supabase-js": "^2.110.7",
    "@types/node": "^25.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "immer": "^10.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.26",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "three": "^0.159.0",
    "three-bvh-csg": "^0.0.16",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.29",
    "zod": "^4.3.6",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jszip": "^3.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.159.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@vitest/ui": "^3.2.7",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "exceljs": "^4.4.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.5.3",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "postcss": "^8.4.31",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
