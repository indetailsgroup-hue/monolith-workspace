+      backPanelInset: 6,
+      shelfCount: 0,
+      dividerCount: 0,
+    },
+    materials: {
+      defaultCore: 'core-1',
+      defaultSurface: 'surface-1',
+      defaultEdge: 'edge-1',
+      overrides: new Map(),
+    },
+    manufacturing: {
+      glueThickness: 0.1,
