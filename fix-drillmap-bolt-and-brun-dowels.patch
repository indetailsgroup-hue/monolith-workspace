+      edges: { top: null, bottom: null, left: null, right: null },
+      grainDirection: 'HORIZONTAL',
+      computed: {
+        realThickness: THICKNESS,
+        cutWidth: horizontalPanelWidth,
+        cutHeight: DEPTH,
+        surfaceArea: 0,
+        edgeLength: 0,
+        cost: 0,
+        co2: 0,
+      },
+      position: [0, HEIGHT - THICKNESS / 2, DEPTH / 2],
+      rotation: [0, 0, 0],
+      visible: true,
+      selected: false,
+    },
+    {
+      id: 'panel-bottom',
+      role: 'BOTTOM',
+      name: 'Bottom Panel',
+      finishWidth: horizontalPanelWidth,
+      finishHeight: DEPTH,
