# Content-addressed records use SHA-256 manifests — bytes must be identical on every platform/checkout.
.gitattributes text eol=lf
docs/prd/** text eol=lf
docs/implementation/** text eol=lf
docs/governance/** text eol=lf
docs/specs/** text eol=lf
scripts/**/*.mjs text eol=lf
package.json text eol=lf
*.sha256 text eol=lf
# Vitest snapshots are generated with LF; pin so autocrlf can't flip them and
# make every local build dirty the working tree (FS-B2-04).
*.snap text eol=lf
# Track A (S17 identity): content-addressed test/evidence + factory sources.
supabase/tests/s17-0162/** text eol=lf
supabase/tests/s17-hosted-auth/** text eol=lf
supabase/functions/factory-api/** text eol=lf
supabase/migrations/0162_factory_server_identity_released_only.sql text eol=lf
.kiro/specs/installation-pm/tasks.md text eol=lf
# Evidence: LF text by default; JSON stays byte-exact (-text) so manifests verify.
docs/evidence/** text eol=lf
docs/evidence/**/*.json -text
docs/evidence/**/*.md text eol=lf
docs/evidence/**/*.sha256 text eol=lf
# S17 Track B black-box interop fixture: byte-exact artifacts from the frozen
# S17-4 generator (eeed1ce6) — any byte change must fail the pinned hashes.
src/packet-verifier/interop/fixtures/*.zip binary
src/packet-verifier/interop/fixtures/*.json -text
